# Copy to .env.local and fill in. Never commit .env.local.

# /api/optimize LLM depth: economy | balanced (default) | quality — trades Anthropic token usage vs. rewrite depth.
# OPTIMIZE_DEPTH=balanced

# Public site URL (no trailing slash). Local: http://localhost:3000 — matches Supabase Redirect URLs + OAuth redirectTo.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon / publishable key — client only>
# SUPABASE_SERVICE_ROLE_KEY=<secret service_role JWT from Dashboard → Settings → API>
#   Must start with eyJ... (long). NOT the sb_publishable_ key — server quota/billing DB writes will fail.

# --- Razorpay ---
# Credit packs use one-time USD orders (see app/lib/billing/packages.ts). Your Razorpay account must support USD / international charges if you use live mode.
# Local dev: omit RAZORPAY_MODE or set RAZORPAY_MODE=test
# Vercel Production: set RAZORPAY_MODE=live (or rely on VERCEL_ENV=production)
# RAZORPAY_MODE=test

# Test mode (default locally)
RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_TEST_KEY_SECRET=xxxxxxxx

# Live mode (set on Vercel Production)
# RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxx
# RAZORPAY_LIVE_KEY_SECRET=xxxxxxxx

# Webhook signing secret from Razorpay Dashboard (test vs live dashboards differ)
RAZORPAY_WEBHOOK_SECRET=xxxxxxxx
